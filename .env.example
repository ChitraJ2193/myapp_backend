# Copy to .env and adjust (never commit .env)
SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=myapp_backend.settings.dev

# PostgreSQL (docker-compose defaults match these)
POSTGRES_DB=myapp_db
POSTGRES_USER=myapp_user
POSTGRES_PASSWORD=myapp_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional local dev: use SQLite without Docker
USE_SQLITE=false

# CORS — comma-separated origins for your iOS / web dev servers
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set true only for local device testing (do not use in production)
CORS_ALLOW_ALL=false

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Staging / production (split settings)
ALLOWED_HOSTS=api.example.com,.example.com
