# Copy to deploy-cloudrun.yml when ready. Fill PROJECT_ID, REGION, AR_REPO, SERVICE_NAME.
# Prerequisites: Artifact Registry repo, Cloud Run API, Cloud Build, service account with deploy + push rights.
# Connect Cloud SQL in Cloud Run UI or add: --add-cloudsql-instances=PROJECT:REGION:INSTANCE

name: Deploy Backend to Cloud Run

on:
  workflow_dispatch:
  push:
    branches: [main]

env:
  PROJECT_ID: YOUR_GCP_PROJECT_ID
  REGION: us-central1
  SERVICE_NAME: myapp-api
  AR_REPO: myapp-docker
  IMAGE_NAME: myapp-api

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: read

    steps:
      - uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ secrets.GCP_SA_KEY }}

      - name: Set up Cloud SDK
        uses: google-github-actions/setup-gcloud@v2

      - name: Configure Docker for Artifact Registry
        run: gcloud auth configure-docker ${{ env.REGION }}-docker.pkg.dev --quiet

      - name: Build and push image
        run: |
          IMAGE="${{ env.REGION }}-docker.pkg.dev/${{ env.PROJECT_ID }}/${{ env.AR_REPO }}/${{ env.IMAGE_NAME }}:${{ github.sha }}"
          docker build -t "$IMAGE" .
          docker push "$IMAGE"
          echo "IMAGE=$IMAGE" >> "$GITHUB_ENV"

      - name: Deploy to Cloud Run
        run: |
          gcloud run deploy ${{ env.SERVICE_NAME }} \
            --image "$IMAGE" \
            --region ${{ env.REGION }} \
            --platform managed \
            --port 8000 \
            --set-env-vars "DJANGO_SETTINGS_MODULE=myapp_backend.settings.production,DEBUG=False" \
            --set-secrets "SECRET_KEY=SECRET_KEY:latest,POSTGRES_PASSWORD=POSTGRES_PASSWORD:latest" \
            --quiet
        # Replace --set-secrets with your Secret Manager secret names, or use --set-env-vars for non-prod only.
        # Add: --add-cloudsql-instances=PROJECT:REGION:INSTANCE
        # Set POSTGRES_HOST etc. via Cloud Run console or additional --set-env-vars.
